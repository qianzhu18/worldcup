# Copy this file to .env before running docker compose.
# Compose reads .env for both build-time NEXT_PUBLIC_* values and runtime values.

APP_PORT=3000
PORT=3000

AI_BASE_URL=https://tokendance.space/gateway/v1
AI_API_KEY=your_api_key_here
AI_MODEL=minimax-m3:free
AI_FALLBACK_MODELS=deepseek-v4-pro,qwen3.7-max
ENABLE_BUILD_AI_CHAMPION=false

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional outbound proxy for Polymarket/API calls.
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1
